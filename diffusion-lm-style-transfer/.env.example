# Project
PROJECT_NAME=diffusion-lm-style-transfer
EXPERIMENT_NAME=baseline

# Paths
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs
OUTPUT_DIR=./outputs

# Training
SEED=42
DEVICE=cuda
NUM_WORKERS=4

# Weights & Biases (optional)
WANDB_PROJECT=diffusion-lm-style-transfer
WANDB_ENTITY=
WANDB_MODE=online   # online | offline | disabled

# HuggingFace
HF_TOKEN=
HF_HOME=~/.cache/huggingface

# Distributed training
MASTER_ADDR=localhost
MASTER_PORT=12355
